                    <img class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCwqTKRJ4IuHc0ZYgcrR7G9XgkYPL3SWp3fSd4CHaixbNyQS_Ew7W_bJVnfcb_GT9RIdZBd2VVBrgTrkd2f65iNKG_ngqe4ilfC8kzQYZ4x6jyfY9oYb_gBNTh2WOf9Ll47AHtN6X1hsQ1hLLp5fUXi4uf0qrGIgt-O-6ind_DkO_GfbdnjqmcZCc6pl7mC9mNz9SE6J4UH0fjwqM0fSoTAg3gxgD_eTpaSryiq0SPyiUy2BOMjhOkLP29PdYjLXWZvqCtjkRamJrE" alt="Excavadora"/>
