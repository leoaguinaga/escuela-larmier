            <form class="border-2 border-outline-variant bg-surface-container-low p-6 md:p-8 grid gap-5">
                <label class="grid gap-2">
                    <span class="font-label-md text-label-md text-on-surface uppercase">Nombre completo</span>
                    <input class="bg-surface border border-outline-variant px-4 py-3 text-on-surface focus:border-primary outline-none" type="text" name="nombre" placeholder="Escribe tu nombre" />
                </label>
                <label class="grid gap-2">
