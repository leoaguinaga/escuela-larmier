                <h3 class="font-headline-md text-headline-md uppercase text-primary">Enfoque laboral</h3>
                <p class="font-body-md text-body-md text-on-surface-variant">Preparación para minería, construcción, agricultura y logística.</p>
            </div>
        </div>
    </div>
</section>
